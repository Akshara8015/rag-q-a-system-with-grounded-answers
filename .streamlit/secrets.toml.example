# Copy these keys into Streamlit Community Cloud secrets or your host's
# environment variables. Do not commit a real secrets.toml file.

OPENAI_API_KEY = "your_openai_api_key_here"
OPENAI_MODEL = "gpt-4o-mini"

CHROMA_API_KEY = "your_chroma_api_key_here"
CHROMA_TENANT = "your_chroma_tenant_here"
CHROMA_DATABASE = "your_chroma_database_here"

# Optional: use a different prefix for per-upload Chroma collections.
CHROMA_COLLECTION_PREFIX = "document_chunks"
