# Environment variables for Document Intelligence Chat

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Chroma Cloud / TryChroma
# Set all three values in your deployment environment or Streamlit secrets.
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_chroma_tenant_here
CHROMA_DATABASE=your_chroma_database_here
CHROMA_COLLECTION_PREFIX=document_chunks

# Optional: local-only fallback when Chroma Cloud values are not set
CHROMA_DB_PATH=./chroma_db
TEMP_PDF_PATH=/tmp

# Optional: Logging
LOG_LEVEL=INFO
